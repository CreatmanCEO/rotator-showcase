# MNEMO (required)
MNEMO_BASE_URL=http://localhost:8080
MNEMO_TOKEN=

# Voice (required for rotator call)
DEEPGRAM_API_KEY=
GROQ_API_KEY=

# MCP transport (default: stdio)
ROTATOR_MCP_TRANSPORT=stdio
# For remote HTTP mode:
# ROTATOR_MCP_TRANSPORT=streamable-http
# ROTATOR_MCP_HOST=0.0.0.0
# ROTATOR_MCP_PORT=18081
# ROTATOR_MCP_TOKEN=
# ROTATOR_MCP_ALLOWED_HOSTS=<TAILSCALE_IP>:18081

# Telemetry
# ROTATOR_TELEMETRY_DB=~/.rotator/telemetry.db
# ROTATOR_CLIENT_HOST=win-creat

# LLM (for chronicle builder, cron paths only)
# OPENROUTER_API_KEY=
# ROTATOR_SONNET=anthropic/claude-sonnet-4.6
# ROTATOR_HAIKU=anthropic/claude-haiku-4.5

# Optional
ROTATOR_LOG_LEVEL=info
